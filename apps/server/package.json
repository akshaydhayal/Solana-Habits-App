{
  "name": "server",
  "version": "0.0.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "npm run build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "db:migrate": "cd ../../packages/db && npm run db:migrate",
    "dev": "npx tsx watch src/index.ts",
    "start": "npx tsx db:migrate && node dist/index.mjs"
  },
  "dependencies": {
    "@ai-sdk/devtools": "^0.0.2",
    "@ai-sdk/google": "^3.0.1",
    "@hono/node-server": "^1.19.11",
    "@my-app/api": "*",
    "@my-app/auth": "*",
    "@my-app/db": "*",
    "@my-app/env": "*",
    "@orpc/openapi": "*",
    "@orpc/server": "*",
    "@orpc/zod": "*",
    "ai": "*",
    "better-auth": "*",
    "dotenv": "*",
    "hono": "*",
    "zod": "*",
    "tsdown": "^0.16.5",
    "typescript": "*"
  },
  "devDependencies": {
    "@my-app/config": "*",
    "@types/bun": "*"
  }
}